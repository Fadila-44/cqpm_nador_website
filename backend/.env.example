APP_NAME="CQPM Nador API"

APP_ENV=local

APP_KEY=

APP_DEBUG=true

APP_TIMEZONE=Africa/Casablanca

APP_URL=http://127.0.0.1:8000



APP_LOCALE=fr

APP_FALLBACK_LOCALE=fr

APP_FAKER_LOCALE=fr_FR



LOG_CHANNEL=stack

LOG_LEVEL=debug



# XAMPP MySQL — create database in phpMyAdmin: cqpm_nador

DB_CONNECTION=mysql

DB_HOST=127.0.0.1

DB_PORT=3306

DB_DATABASE=cqpm_nador

DB_USERNAME=root

DB_PASSWORD=



SESSION_DRIVER=file

SESSION_LIFETIME=120



# React frontend URL (for CORS)

FRONTEND_URL=http://127.0.0.1:5173



# Admin login (created by: php artisan db:seed)

ADMIN_NAME="CQPM Admin"

ADMIN_EMAIL=admin@cqpm.ma

ADMIN_PASSWORD=changeme



# Email address that receives form notifications

ADMIN_NOTIFY_EMAIL=admin@cqpm.ma



# Mail — use "log" for local dev (emails saved in storage/logs/laravel.log)

# For real emails, switch to smtp and fill SMTP settings below

MAIL_MAILER=log

MAIL_HOST=127.0.0.1

MAIL_PORT=1025

MAIL_USERNAME=null

MAIL_PASSWORD=null

MAIL_ENCRYPTION=null

MAIL_FROM_ADDRESS=noreply@cqpm.ma

MAIL_FROM_NAME="${APP_NAME}"



BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

QUEUE_CONNECTION=sync

CACHE_STORE=file

